# --- Anthropic (receipt parsing) ---
ANTHROPIC_API_KEY=
PARSER_MODEL=claude-opus-4-8

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; webhook upserts (bypasses RLS)

# --- Meta WhatsApp Cloud API ---
WHATSAPP_VERIFY_TOKEN=              # GET webhook verify handshake
WHATSAPP_APP_SECRET=               # X-Hub-Signature-256 HMAC
WHATSAPP_ACCESS_TOKEN=             # Graph API media download + replies
WHATSAPP_PHONE_NUMBER_ID=

# --- Resend (monthly auto-email) ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # used for auth redirect callbacks
